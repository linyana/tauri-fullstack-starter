{
  "name": "tauri-starter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:app": "vite",
    "dev:api": "bun --watch src/api/main.ts",
    "dev": "concurrently \"bun run dev:app\" \"bun run dev:api\"",
    "build": "tsc && vite build",
    "build:api-binary": "node scripts/build-api-binary.cjs",
    "build:tauri": "bun run build && bun run build:api-binary",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "bun run build:api-binary && bun run tauri dev",
    "prisma:push": "prisma db push",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "antd": "^6.3.3",
    "@ant-design/icons": "^6.1.0",
    "@elysiajs/cors": "^1.4.1",
    "@octokit/rest": "^22.0.1",
    "@prisma/client": "5.3.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "axios": "^1.13.6",
    "dayjs": "^1.11.20",
    "dotenv": "^17.3.1",
    "elysia": "^1.4.28",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "simple-git": "^3.33.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "typescript": "~5.9.3",
    "vite": "8.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "prisma": "5.3.0",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "concurrently": "^9.2.1"
  }
}
